# =============================================================================
# Ambiente — ajuste DEBUG e SECRET_KEY conforme DEV ou PRD
# =============================================================================
# DEV: DEBUG=true  + SECRET_KEY=dev-secret-key (qualquer valor para testes)
# PRD: DEBUG=false + SECRET_KEY=<chave-forte-aleatoria-min-32-chars>
# =============================================================================
DEBUG=true
SECRET_KEY=change-me-in-production

# Banco de dados
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=autonomous_agent
# Portas expostas no host (DEV usa alternativas para evitar conflito local)
POSTGRES_PORT=25432
# URL para acesso fora do Docker (migrations locais, DBeaver, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:25432/autonomous_agent

# Redis
REDIS_PORT=16379
REDIS_URL=redis://localhost:16379/0
CELERY_BROKER_URL=redis://localhost:16379/1
CELERY_RESULT_BACKEND=redis://localhost:16379/2

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Telegram
TELEGRAM_BOT_TOKEN=...

# ElevenLabs
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# D-ID Avatar
DID_API_KEY=...

# Frontend / Backend
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000
BACKEND_PORT=8000
