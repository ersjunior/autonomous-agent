# =============================================================================
# Ambiente — ajuste DEBUG e SECRET_KEY conforme DEV ou PRD
# =============================================================================
# DEV: DEBUG=true  + SECRET_KEY=dev-secret-key (qualquer valor para testes)
# PRD: DEBUG=false + SECRET_KEY=<chave-forte-aleatoria-min-32-chars>
# =============================================================================
DEBUG=true
SECRET_KEY=change-me-in-production

# Banco de dados
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=autonomous_agent
# Portas expostas no host (DEV usa alternativas para evitar conflito local)
POSTGRES_PORT=25432
# URL para acesso fora do Docker (migrations locais, DBeaver, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:25432/autonomous_agent

# Banco dedicado para testes de integração (pytest tests/integration).
# Deve terminar com _test e ser diferente de DATABASE_URL.
# Host local (fora do Docker): localhost + POSTGRES_PORT.
# Dentro do container backend: host postgres, porta 5432.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:25432/autonomous_agent_test
# Criar o banco: o conftest de integração cria autonomous_agent_test automaticamente
# na primeira execução (via psycopg2). Alternativa manual:
#   docker compose -f infra/docker/docker-compose.yml exec postgres \
#     psql -U postgres -c "CREATE DATABASE autonomous_agent_test;"

# Redis / Celery
REDIS_PORT=16379
REDIS_URL=redis://localhost:16379/0
CELERY_BROKER_URL=redis://localhost:16379/1
CELERY_RESULT_BACKEND=redis://localhost:16379/2

# ============================================================
# PROVIDERS — padrão é a stack open source (sem custo, sem chaves).
# Troque para 'openai' / 'elevenlabs' para usar os serviços comerciais.
# ============================================================
LLM_PROVIDER=ollama
STT_PROVIDER=faster_whisper
TTS_PROVIDER=coqui
# 768 com Ollama (nomic-embed-text); use 1536 com LLM_PROVIDER=openai
EMBEDDING_DIMENSIONS=768

# ============================================================
# Stack open source (padrão) — valores já prontos para uso no Docker Compose
# ============================================================
# Ollama (LLM + embeddings)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
OLLAMA_PORT=11434
# Mantém o modelo na memória (evita reload por inatividade). Ex.: 24h, -1 (infinito), 0 (descarrega já)
OLLAMA_KEEP_ALIVE=24h

# faster-whisper (STT)
WHISPER_BASE_URL=http://faster-whisper:8001
WHISPER_MODEL=large-v3-turbo
# large-v3-turbo: ~2x mais rápido que large-v3, qualidade PT próxima; medium se CPU limitado
# Porta no host (remapeie ex.: 18001 se 8001 estiver ocupada; porta interna do container = 8001)
WHISPER_PORT=8001
# GPU (padrão com NVIDIA Container Toolkit): cuda + float16. Sem GPU: cpu + int8.
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# Coqui XTTS-v2 (TTS)
# Rede interna do Docker usa 8002; COQUI_PORT abaixo e a porta publicada no host.
COQUI_BASE_URL=http://coqui-tts:8002
# Porta no host (remapeie ex.: 18002 se 8002 estiver ocupada; porta interna do container = 8002)
COQUI_PORT=8002
COQUI_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
COQUI_VOICE_SAMPLE=/voices/reference.wav
# GPU (padrão com NVIDIA Container Toolkit): cuda. Sem GPU: cpu.
COQUI_DEVICE=cuda

# ============================================================
# Paths internos nos containers (normalmente não altere)
# ============================================================
# COQUI_VOICES_ROOT=/voices
# VOICE_AUDIO_ROOT=/workspace/voice_audio

# Inbound de voz PSTN (Twilio) — VOICE_INBOUND_MODE: record | gather | stream
# (apenas record implementado hoje; gather/stream reservados para versões futuras)
VOICE_INBOUND_MODE=record
# Saudação falada na abertura da ligação (editável também na UI → Comportamento)
VOICE_INBOUND_GREETING=Olá! Você ligou para o nosso atendimento. Como posso ajudar?
# Inatividade na chamada (aviso após N segundos acumulados de silêncio; encerramento após mais M)
VOICE_SILENCE_WARNING_SECONDS=30
VOICE_SILENCE_CLOSE_SECONDS=15
# Twilio <Record>: silêncio após a fala para encerrar gravação (responsivo; não confundir com inatividade)
VOICE_RECORD_SILENCE_TIMEOUT_SEC=2
# Twilio <Record>: duração máxima da fala do cliente
VOICE_RECORD_MAX_LENGTH_SEC=30
# RAG enxuto só no canal voice (memória de longo prazo; KB usa rag_top_k global)
VOICE_RAG_TOP_K=3
# Threshold de similaridade na voz (memória de contato; global RAG_SIMILARITY_THRESHOLD costuma ser 0.0)
VOICE_RAG_SIMILARITY_THRESHOLD=0.5
# Threshold de KB só na voz (global KB_SIMILARITY_THRESHOLD=0.62 permanece para WhatsApp/Telegram)
VOICE_KB_SIMILARITY_THRESHOLD=0.50
# Voz inbound assíncrona — polling turn-ready (Redirect loop; Twilio webhook ~15s)
VOICE_TURN_MAX_POLL_ATTEMPTS=60
VOICE_TURN_POLL_PAUSE_SECONDS=1
# Limite rígido de tokens da resposta LLM só no canal voice (Twilio ~15s). 0 = sem limite.
VOICE_RESPONSE_MAX_TOKENS=35

# =============================================================================
# Motor de acionamento (Camadas A–D) — agente ACTIVE, campanhas outbound
# =============================================================================
# Fuso para janela de horário (Camada B). Beat Celery roda em UTC; a checagem
# converte para este fuso (padrão America/Sao_Paulo).
ACTIVATION_TIMEZONE=America/Sao_Paulo

# Camada D — TTL dos slots Redis (sem callback Twilio; estimativa + rede de segurança)
# Voz/vídeo: duração estimada da chamada até o holder expirar e liberar o slot.
CALL_SLOT_TTL_SECONDS=300
# WhatsApp/Telegram: TTL de segurança do holder; liberação principal ao encerrar conversa.
CHAT_SLOT_TTL_SECONDS=86400

# Janela de conversa ativa outbound (roteamento inbound ACTIVE; Camada C/D).
# Encerra se (agora - data_ultimo_contato) > N horas. Separado do sweep abaixo.
ACTIVE_CONVERSATION_TIMEOUT_HOURS=24

# Sweep Celery (hora em hora): marca lead_interaction acionado sem resposta como nao_atendido
STATUS_TIMEOUT_HOURS=48

# Mensageria — sweep de inatividade (em_andamento, lifecycle_version >= 1)
INACTIVITY_WARNING_MINUTES=20
INACTIVITY_CLOSE_MINUTES=20
INACTIVITY_SWEEP_SECONDS=60

# R-A — capacidade global ponderada (ativo + receptivo) e fila receptiva
MAX_WEIGHTED_CAPACITY=50
CHANNEL_WEIGHT_WHATSAPP=1
CHANNEL_WEIGHT_TELEGRAM=1
CHANNEL_WEIGHT_VOICE=3
RECEPTIVE_QUEUE_BEAT_SECONDS=30
RECEPTIVE_QUEUE_PAYLOAD_TTL_SECONDS=86400

# R-B — SLA da fila receptiva e abandono (só voz, quando inbound existir)
SERVICE_LEVEL_TARGET_SECONDS=20
QUEUE_ABANDON_TIMEOUT_SECONDS=60

# B-2 — modo humano após escalonamento (bot para de responder; Redis TTL)
# Legado — alias do queue TTL curto (H-2); preferir HUMAN_HANDOFF_QUEUE_TTL_SECONDS
HUMAN_MODE_TTL_SECONDS=1800
# Intervalo mínimo entre mensagens automáticas de espera (evita spam)
HUMAN_MODE_NOTIFY_INTERVAL_SECONDS=300

# H-2 — ciclo de finalização do handoff humano
# Sem assumir: após N segundos o sweep devolve o lead ao bot (exit_human_mode)
HUMAN_HANDOFF_QUEUE_TTL_SECONDS=1800
# Após assumir: janela para finalizar manualmente; depois auto NEG:ABANDONO
HUMAN_HANDOFF_FINALIZE_TTL_SECONDS=14400
# Intervalo do Celery Beat (sweep_human_handoff_timeouts)
HUMAN_HANDOFF_SWEEP_SECONDS=60

# Monitoramento — janela de conversas ativas (GET /monitoring/active-conversations)
ACTIVE_CONVERSATIONS_WINDOW_MINUTES=10

# H-1 — handoff humano: notificação do operador + link wa.me ao lead no escalonamento
# Número WhatsApp do atendente (E.164 ou DDD+número BR). Vazio = desabilitado.
HUMAN_HANDOFF_WHATSAPP=
# Ativar notificação/link no escalonamento (true|false). Requer número preenchido.
HUMAN_HANDOFF_ENABLED=true

# KB-1 — base de conhecimento documental (upload + ingestão assíncrona)
KB_UPLOADS_ROOT=/workspace/kb_uploads
KB_CHUNK_SIZE=512
KB_CHUNK_OVERLAP=64
KB_MAX_UPLOAD_BYTES=10485760
# KB-2 — recuperação semântica (0 = usa RAG_TOP_K; threshold mais alto evita injetar lixo)
KB_TOP_K=0
KB_SIMILARITY_THRESHOLD=0.62

# R-C — Capacidade / Erlang (estimativa de hardware + dimensionamento analítico)
# MAX_WEIGHTED_CAPACITY_OVERRIDE>0 força o teto; 0 = derivado de CPU/RAM (psutil no container)
MAX_WEIGHTED_CAPACITY_OVERRIDE=0
# Custo em unidades abstratas de recurso por canal simultâneo (estimativa, não runtime)
CHANNEL_COST_WHATSAPP=1
CHANNEL_COST_TELEGRAM=1
CHANNEL_COST_VOICE=3
CAPACITY_CPU_UNITS_PER_CORE=10
CAPACITY_MB_PER_UNIT=512
DEFAULT_AHT_SECONDS=180
CAPACITY_HISTORY_DAYS=7
ERLANG_TARGET_SERVICE_LEVEL=0.80

# ============================================================
# Serviços comerciais — OPCIONAIS (preencha apenas se trocar o provider)
# ============================================================
# OpenAI (apenas se LLM_PROVIDER=openai ou STT_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Canais padrão (seed no startup): ao subir, a API cria 3 canais para admin@admin.com
# — WhatsApp_Agent, Telegram_Agent, Voice_Agent — com credenciais destas variáveis.
# Campos vazios geram canal inativo; complete na UI em /dashboard/channels.

# Twilio (apenas para canais WhatsApp/Voz)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
# Número WhatsApp (formato whatsapp:+1... ou +1... — o código adiciona o prefixo se faltar)
TWILIO_PHONE_NUMBER=+1...
# Número PSTN só para voz (opcional; se vazio, usa TWILIO_PHONE_NUMBER sem prefixo whatsapp:)
TWILIO_VOICE_NUMBER=

# ---------------------------------------------------------------------------
# Cloudflare Tunnel (TUN-1) — URL pública do backend no Docker
# ---------------------------------------------------------------------------
# Expõe o backend (porta 8000) na internet para Twilio (voz outbound + WhatsApp
# inbound) e Telegram (TELEGRAM_MODE=webhook). O serviço cloudflared roda no
# Compose (infra/docker/docker-compose.yml); alterne o modo só via .env — não
# edite o compose.
#
# Como o backend resolve a URL (app/core/config.py):
#   1. PUBLIC_BASE_URL no .env → sempre vence (named ou manual).
#   2. TUNNEL_MODE=temporary + PUBLIC_BASE_URL vazio → lê TUNNEL_URL_FILE
#      (quick tunnel grava a URL *.trycloudflare.com em runtime).
#   3. TUNNEL_MODE=named + PUBLIC_BASE_URL vazio → URL indisponível (erro).
#
# --- Modo temporary (default) — dev rápido, URL aleatória ---
#   TUNNEL_MODE=temporary
#   PUBLIC_BASE_URL=                    (deixe vazio)
#   CLOUDFLARE_TUNNEL_TOKEN=            (deixe vazio)
#   cloudflared abre quick tunnel → http://backend:8000 e grava a URL em
#   TUNNEL_URL_FILE. Reiniciar o container gera URL nova (*.trycloudflare.com).
#
# --- Modo named — demo/produção, URL fixa no seu domínio ---
#   TUNNEL_MODE=named
#   CLOUDFLARE_TUNNEL_TOKEN=eyJ...      (token do connector no Zero Trust)
#   PUBLIC_BASE_URL=https://webhook.seudominio.com   (SEM barra no final)
#   No painel Cloudflare (túnel "autonomous-agent" ou similar):
#     Public Hostname: webhook.seudominio.com → http://backend:8000
#   (use o hostname do serviço Docker "backend", não localhost.)
#   Rode apenas UM conector por ambiente (container Docker OU cloudflared no
#   Windows — não os dois ao mesmo tempo no mesmo túnel).
#   Após alterar infra/docker/cloudflared/entrypoint.sh, rebuild obrigatório:
#     docker compose --env-file .env -f infra/docker/docker-compose.yml \
#       -f infra/docker/docker-compose.dev.yml up -d --build cloudflared
#
# --- Modo manual — sem cloudflared (ngrok, IP público, etc.) ---
#   Preencha só PUBLIC_BASE_URL; deixe TUNNEL_MODE=temporary e pare o serviço
#   cloudflared se não for usar o túnel Cloudflare.
#
TUNNEL_MODE=temporary
CLOUDFLARE_TUNNEL_TOKEN=
# Caminho compartilhado backend ↔ cloudflared (volume tunnel_data → /shared).
# Só usado em TUNNEL_MODE=temporary; ignorado quando PUBLIC_BASE_URL está setada.
TUNNEL_URL_FILE=/shared/tunnel_url.txt

# URL pública do backend (Twilio TwiML, webhook WhatsApp, webhook Telegram).
# SEM barra no final. Ex.: https://webhook.seudominio.com
# temporary: deixe vazio (resolvido automaticamente pelo quick tunnel).
# named/manual: obrigatório — deve coincidir com o hostname no Cloudflare/ngrok.
PUBLIC_BASE_URL=

# Telegram (canal Telegram)
TELEGRAM_BOT_TOKEN=...
# polling (default): bot puxa updates (getUpdates) — processo SEPARADO, não no uvicorn.
#   Subir: docker compose --profile telegram-polling up -d telegram-polling
#   Ou manual: docker exec -it autonomous-agent-worker python -c "..."
# webhook: Telegram POSTa em /api/v1/channels/webhooks/telegram (setWebhook no startup).
#   Exige PUBLIC_BASE_URL / túnel Cloudflare (TUN-1). NÃO rode telegram-polling junto.
TELEGRAM_MODE=polling

# ElevenLabs (apenas se TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Frontend / Backend (portas no host)
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Auth JWT (opcional — padrão 1440 min = 24h)
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

