# =============================================================================
# Ambiente — ajuste DEBUG e SECRET_KEY conforme DEV ou PRD
# =============================================================================
# DEV: DEBUG=true  + SECRET_KEY=dev-secret-key (qualquer valor para testes)
# PRD: DEBUG=false + SECRET_KEY=<chave-forte-aleatoria-min-32-chars>
# =============================================================================
DEBUG=true
SECRET_KEY=change-me-in-production

# Banco de dados
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=autonomous_agent
# Portas expostas no host (DEV usa alternativas para evitar conflito local)
POSTGRES_PORT=25432
# URL para acesso fora do Docker (migrations locais, DBeaver, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:25432/autonomous_agent

# Redis / Celery
REDIS_PORT=16379
REDIS_URL=redis://localhost:16379/0
CELERY_BROKER_URL=redis://localhost:16379/1
CELERY_RESULT_BACKEND=redis://localhost:16379/2

# ============================================================
# PROVIDERS — padrão é a stack open source (sem custo, sem chaves).
# Troque para 'openai' / 'elevenlabs' / 'did' para usar os serviços comerciais.
# ============================================================
LLM_PROVIDER=ollama
STT_PROVIDER=faster_whisper
TTS_PROVIDER=coqui
AVATAR_PROVIDER=sadtalker
# 768 com Ollama (nomic-embed-text); use 1536 com LLM_PROVIDER=openai
EMBEDDING_DIMENSIONS=768

# ============================================================
# Stack open source (padrão) — valores já prontos para uso no Docker Compose
# ============================================================
# Ollama (LLM + embeddings)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
OLLAMA_PORT=11434
# Mantém o modelo na memória (evita reload por inatividade). Ex.: 24h, -1 (infinito), 0 (descarrega já)
OLLAMA_KEEP_ALIVE=24h

# faster-whisper (STT)
WHISPER_BASE_URL=http://faster-whisper:8001
WHISPER_MODEL=large-v3
# Porta no host (remapeie ex.: 18001 se 8001 estiver ocupada; porta interna do container = 8001)
WHISPER_PORT=8001
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Coqui XTTS-v2 (TTS)
COQUI_BASE_URL=http://coqui-tts:8002
# Porta no host (remapeie ex.: 18002 se 8002 estiver ocupada; porta interna do container = 8002)
COQUI_PORT=8002
COQUI_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
COQUI_VOICE_SAMPLE=/voices/reference.wav

# SadTalker (avatar em vídeo) — requer GPU NVIDIA + Container Toolkit
SADTALKER_BASE_URL=http://sadtalker:8003
SADTALKER_PORT=8003

# ============================================================
# Paths internos nos containers (normalmente não altere)
# ============================================================
# COQUI_VOICES_ROOT=/voices
# VOICE_AUDIO_ROOT=/workspace/voice_audio
# AVATAR_VIDEO_ROOT=/workspace/avatar_video
# AVATARS_ROOT=/avatars
# AVATAR_DEFAULT_IMAGE=default.png

# =============================================================================
# Motor de acionamento (Camadas A–D) — agente ACTIVE, campanhas outbound
# =============================================================================
# Fuso para janela de horário (Camada B). Beat Celery roda em UTC; a checagem
# converte para este fuso (padrão America/Sao_Paulo).
ACTIVATION_TIMEZONE=America/Sao_Paulo

# Camada D — TTL dos slots Redis (sem callback Twilio; estimativa + rede de segurança)
# Voz/vídeo: duração estimada da chamada até o holder expirar e liberar o slot.
CALL_SLOT_TTL_SECONDS=300
# WhatsApp/Telegram: TTL de segurança do holder; liberação principal ao encerrar conversa.
CHAT_SLOT_TTL_SECONDS=86400

# Janela de conversa ativa outbound (roteamento inbound ACTIVE; Camada C/D).
# Encerra se (agora - data_ultimo_contato) > N horas. Separado do sweep abaixo.
ACTIVE_CONVERSATION_TIMEOUT_HOURS=24

# Sweep Celery (hora em hora): marca lead_interaction acionado sem resposta como nao_atendido
STATUS_TIMEOUT_HOURS=48

# ============================================================
# Serviços comerciais — OPCIONAIS (preencha apenas se trocar o provider)
# ============================================================
# OpenAI (apenas se LLM_PROVIDER=openai ou STT_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Canais padrão (seed no startup): ao subir, a API cria 4 canais para admin@admin.com
# — WhatsApp_Agent, Telegram_Agent, Voice_Agent, Video_Agent — com credenciais
# destas variáveis. Campos vazios geram canal inativo (exceto Video_Agent, ativo
# com SadTalker local); complete na UI em /dashboard/channels.

# Twilio (apenas para canais WhatsApp/Voz)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
# Número WhatsApp (formato whatsapp:+1... ou +1... — o código adiciona o prefixo se faltar)
TWILIO_PHONE_NUMBER=+1...
# Número PSTN só para voz (opcional; se vazio, usa TWILIO_PHONE_NUMBER sem prefixo whatsapp:)
TWILIO_VOICE_NUMBER=

# URL pública do backend para a Twilio buscar o TwiML das chamadas de voz.
# Dev: ngrok, Cloudflare Tunnel, etc. SEM barra no final.
PUBLIC_BASE_URL=https://seu-link-aqui.ngrok-free.dev

# Telegram (apenas para o canal Telegram / entrega de vídeo avatar)
TELEGRAM_BOT_TOKEN=...

# ElevenLabs (apenas se TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# D-ID Avatar (apenas se AVATAR_PROVIDER=did)
DID_API_KEY=...

# Frontend / Backend (portas no host)
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Auth JWT (opcional — padrão 1440 min = 24h)
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
