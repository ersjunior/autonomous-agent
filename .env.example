# =============================================================================
# Ambiente — ajuste DEBUG e SECRET_KEY conforme DEV ou PRD
# =============================================================================
# DEV: DEBUG=true  + SECRET_KEY=dev-secret-key (qualquer valor para testes)
# PRD: DEBUG=false + SECRET_KEY=<chave-forte-aleatoria-min-32-chars>
# =============================================================================
DEBUG=true
SECRET_KEY=change-me-in-production

# Banco de dados
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=autonomous_agent
# Portas expostas no host (DEV usa alternativas para evitar conflito local)
POSTGRES_PORT=25432
# URL para acesso fora do Docker (migrations locais, DBeaver, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:25432/autonomous_agent

# Redis
REDIS_PORT=16379
REDIS_URL=redis://localhost:16379/0
CELERY_BROKER_URL=redis://localhost:16379/1
CELERY_RESULT_BACKEND=redis://localhost:16379/2

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# 1536 com OpenAI; use 768 com LLM_PROVIDER=ollama (nomic-embed-text)
EMBEDDING_DIMENSIONS=1536

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Telegram
TELEGRAM_BOT_TOKEN=...

# ElevenLabs
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# D-ID Avatar
DID_API_KEY=...

# ============================================================
# PROVIDERS — escolha 'openai' ou 'ollama' / 'faster_whisper' etc.
# ============================================================
LLM_PROVIDER=openai
STT_PROVIDER=openai
TTS_PROVIDER=elevenlabs
AVATAR_PROVIDER=did

# Ollama (se LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
# Com Ollama: EMBEDDING_DIMENSIONS=768
OLLAMA_PORT=11434
# Mantém o modelo na memória (evita reload por inatividade). Ex.: 24h, -1 (infinito), 0 (descarrega já)
OLLAMA_KEEP_ALIVE=24h

# faster-whisper (se STT_PROVIDER=faster_whisper)
WHISPER_BASE_URL=http://faster-whisper:8001
WHISPER_MODEL=large-v3
WHISPER_PORT=8001

# Coqui XTTS-v2 (se TTS_PROVIDER=coqui)
COQUI_BASE_URL=http://coqui-tts:8002
COQUI_VOICE_SAMPLE=
COQUI_PORT=8002

# SadTalker (se AVATAR_PROVIDER=sadtalker)
SADTALKER_BASE_URL=http://sadtalker:8003

# Frontend / Backend
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000
BACKEND_PORT=8000
