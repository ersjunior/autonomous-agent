# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
.venv/
venv/
_env/

# Node / Next.js
node_modules/
.next/
dist/
build/

# Variáveis de ambiente (nunca commitar)
.env
.env.local
.env.production
.env.*.local

# Base de conhecimento
backend/scripts/kb_seed_local/

# Limpeza operacional local (SQL one-off, não versionar)
backend/scripts/cleanup_local/

# Amostras de voz Coqui (não commitar áudios de referência reais)
infra/docker/coqui-tts/voices/*.wav
!infra/docker/coqui-tts/voices/.gitkeep

# Avatar — uploads do usuário (manter default.png de exemplo versionado)
infra/docker/sadtalker/avatars/avatar.png
infra/docker/sadtalker/avatars/avatar.jpg
infra/docker/sadtalker/avatars/avatar.jpeg

# Artefatos gerados em runtime (volumes / testes locais)
*.mp3
*.mp4
*.wav
teste_audio.mp3
backend/celerybeat-schedule
infra/docker/coqui-build.log
frontend/tsconfig.tsbuildinfo
kb_uploads/

# Fallback da apresentação (binários locais; README versionado)
docs/demo-assets/**
!docs/demo-assets/README.md

# OS
.DS_Store
Thumbs.db

# Cursor (mantém as rules, ignora config pessoal)
.cursor/mcp.json

# Terraform
infra/**/.terraform/
infra/**/*.tfstate
infra/**/*.tfstate.backup
infra/**/.terraform.lock.hcl
